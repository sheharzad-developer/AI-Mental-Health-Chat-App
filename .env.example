# Google AI Studio / Gemini — if set, the app uses Gemini first
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional (default: gemini-2.5-flash-lite — often better free-tier limits than 2.0-flash)
# GEMINI_MODEL=gemini-2.5-flash-lite
# Comma-separated extras to try if the primary model hits 429 / quota
# GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-1.5-flash

# OpenAI — used only if GEMINI_API_KEY is not set
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_xxx
# Price ID from Dashboard → Products → pick a recurring price (price_xxx)
STRIPE_PRICE_ID=price_xxx
# From `stripe listen` or Dashboard → Developers → Webhooks (whsec_xxx)
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Where Stripe redirects after success / cancel
STRIPE_SUCCESS_URL=http://localhost:3000/success
STRIPE_CANCEL_URL=http://localhost:3000/cancel
# Optional: port for server.js (default 4242)
STRIPE_SERVER_PORT=4242
